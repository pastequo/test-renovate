{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",

    "commitMessagePrefix": "NO-ISSUE: ",
    "labels": [
        "lgtm",
        "approved"
    ],
    "prHourlyLimit": 0,
    "prConcurrentLimit": 0,
    "enabledManagers": [
        "custom.regex",
        "tekton",
        "rpm-lockfile"
    ],
    "tekton": {
        "managerFilePatterns": [
            "/^.tekton/*/"
        ]
    },

    "customManagers": [
        {
            "customType": "regex",
            "managerFilePatterns": [
                "/^Dockerfile.image-service-build$/"
            ],
            "matchStrings": [
                "ARG GOLANGCI_LINT_VERSION=(?<currentValue>[^\\s]+)\\n"
            ],
            "depNameTemplate": "github.com/golangci/golangci-lint",
            "datasourceTemplate": "go"
        }
    ],

    "packageRules": [
        {
            "groupName": "Linter",
            "addLabels": ["linter"],
            "matchDatasources": ["go"],
            "matchPackageNames": ["github.com/golangci/golangci-lint"]
        },
        {
            "matchUpdateTypes": ["major"],
            "matchDatasources": ["go"],
            "matchPackageNames": ["github.com/golangci/golangci-lint"],
            "enabled": false
        }
    ]
}
